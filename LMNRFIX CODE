<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LMNRFIX — Harmful Frequency Detector</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600;700&display=swap');
:root {
  --bg:#09060a;--surface:#0d0904;--surface2:#130c05;--surface3:#190f06;
  --border:rgba(222,145,81,0.09);--border2:rgba(222,145,81,0.18);
  --text:#b07848;--text-dim:#3a2010;--text-bright:#fde8d0;
  --accent:#de9151;--accent-glow:rgba(222,145,81,0.25);
  --danger:#de9151;--danger-glow:rgba(222,145,81,0.18);
  --warn:#a85f28;--warn-glow:rgba(168,95,40,0.14);
  --safe:#de9151;--eq-curve:#de9151;
  --clash:#de9151;--clash-glow:rgba(222,145,81,0.16);
  --scanline:rgba(20,8,0,0.28);
}

*{margin:0;padding:0;box-sizing:border-box;}

body{
  background:var(--bg);color:var(--text);
  font-family:'Share Tech Mono',monospace;
  font-size:11px;height:100vh;display:flex;flex-direction:column;
  overflow:hidden;user-select:none;
  background-image:
    repeating-linear-gradient(0deg,transparent,transparent 2px,var(--scanline) 2px,var(--scanline) 4px);
  background-size:100% 4px;
}

/* ── TOP BAR ── */
.topbar{
  display:flex;align-items:center;justify-content:space-between;
  height:40px;padding:0 14px;
  background:linear-gradient(180deg,#060910 0%,#09060a 100%);
  border-bottom:1px solid var(--border2);
  flex-shrink:0;
  box-shadow:0 1px 20px rgba(222,145,81,0.06);
}
.topbar-left{display:flex;align-items:center;gap:12px;}
.logo{
  font-family:'Rajdhani',sans-serif;font-weight:700;font-size:16px;
  color:var(--accent);letter-spacing:.2em;text-transform:uppercase;
  text-shadow:0 0 12px rgba(222,145,81,.8),0 0 32px rgba(196,100,40,.35);
}
.logo span{color:#7a3e14;text-shadow:0 0 10px rgba(100,50,16,.6);}
.pill{
  font-size:9px;color:rgba(255,255,255,.5);
  background:transparent;border:1px solid rgba(222,145,81,.12);
  padding:2px 8px;letter-spacing:.15em;text-transform:uppercase;
  clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%);
}
.topbar-center{display:flex;align-items:center;gap:2px;}
.tab{
  font-size:9px;letter-spacing:.14em;color:rgba(255,255,255,.35);
  padding:5px 14px;cursor:pointer;transition:all .15s;
  text-transform:uppercase;
  border-bottom:2px solid transparent;
}
.tab:hover{color:var(--text);}
.tab.active{
  color:var(--accent);border-bottom-color:var(--accent);
  text-shadow:0 0 8px rgba(222,145,81,.5);
}
.topbar-right{display:flex;align-items:center;gap:6px;}
#fileStatus{
  font-size:9px;color:rgba(255,255,255,.45);max-width:150px;
  overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
  letter-spacing:.04em;
}
.topbar-btn{
  font-size:9px;letter-spacing:.12em;color:rgba(255,255,255,.35);
  background:transparent;
  border:1px solid rgba(222,145,81,.15);
  padding:4px 12px;cursor:pointer;
  transition:all .15s;text-transform:uppercase;
  clip-path:polygon(4px 0%,100% 0%,calc(100% - 4px) 100%,0% 100%);
}
.topbar-btn:hover{
  color:var(--accent);border-color:var(--accent);
  background:rgba(222,145,81,.06);
  box-shadow:0 0 10px rgba(222,145,81,.15);
}
.topbar-btn:disabled{opacity:.2;cursor:default;}
.topbar-btn.eq-active{
  color:var(--eq-curve);border-color:var(--eq-curve);
  background:rgba(222,145,81,.07);
  box-shadow:0 0 10px rgba(222,145,81,.15);
  text-shadow:0 0 8px rgba(222,145,81,.5);
}
.topbar-btn.clash-active{
  color:var(--clash);border-color:var(--clash);
  background:rgba(222,145,81,.07);
  box-shadow:0 0 10px rgba(222,145,81,.15);
  text-shadow:0 0 8px rgba(222,145,81,.5);
}

/* ── MAIN ── */
.main{display:flex;flex:1;overflow:hidden;gap:1px;background:rgba(222,145,81,.04);}
.eq-wrap{
  flex:1;display:flex;flex-direction:column;
  background:var(--bg);position:relative;overflow:hidden;
}

/* Drop overlay */
#dropOverlay{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:20;pointer-events:none;transition:all .25s;}
#dropOverlay.drag-over{background:rgba(222,145,81,.03);outline:1px solid rgba(222,145,81,.4);outline-offset:-1px;}
.drop-prompt{display:flex;flex-direction:column;align-items:center;gap:12px;opacity:1;transition:opacity .2s;}
.drop-prompt.hidden{opacity:0;pointer-events:none;}
.drop-icon-ring{
  width:64px;height:64px;
  border:1px solid rgba(222,145,81,.2);
  display:flex;align-items:center;justify-content:center;
  font-size:24px;color:rgba(222,145,81,.35);
  box-shadow:0 0 20px rgba(222,145,81,.08),inset 0 0 20px rgba(222,145,81,.04);
  clip-path:polygon(12px 0%,100% 0%,calc(100% - 12px) 100%,0% 100%);
}
.drop-title{font-family:'Rajdhani',sans-serif;font-size:14px;font-weight:600;color:rgba(222,145,81,.4);letter-spacing:.2em;text-transform:uppercase;}
.drop-sub{font-size:9px;color:rgba(255,255,255,.5);letter-spacing:.1em;}
#fileInput{display:none;}
#eqCanvas{width:100%;height:100%;display:block;}

/* Tooltip */
#tooltip{
  position:fixed;background:#030408;
  border:1px solid var(--accent);border-left:2px solid var(--accent);
  padding:4px 10px;font-size:10px;color:var(--accent);
  pointer-events:none;opacity:0;transition:opacity .1s;z-index:100;white-space:nowrap;
  box-shadow:0 0 12px rgba(222,145,81,.2);
  text-shadow:0 0 6px rgba(222,145,81,.4);
  clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%);
}

/* ── RIGHT PANEL ── */
.right-panel{
  width:240px;
  background:linear-gradient(180deg,#120800 0%,#0a0500 100%);
  display:flex;flex-direction:column;flex-shrink:0;
  border-left:1px solid var(--border2);
}
.rp-section{
  padding:12px 14px;
  border-bottom:1px solid var(--border);
}
.rp-label{
  font-size:8px;letter-spacing:.2em;color:rgba(255,255,255,.35);
  text-transform:uppercase;margin-bottom:10px;
}

/* Meters */
.meter-wrap{display:flex;flex-direction:column;gap:6px;}
.meter-row{display:flex;align-items:center;gap:8px;}
.meter-ch{font-size:9px;color:rgba(255,255,255,.5);width:8px;}
.meter-track{
  flex:1;height:4px;
  background:rgba(222,145,81,.05);
  overflow:hidden;
}
.meter-fill{
  height:100%;width:0%;transition:width .06s;
  background:linear-gradient(90deg,#de9151 0%,#a85f28 72%,#de9151 100%);
  box-shadow:0 0 6px rgba(222,145,81,.3);
}
.meter-val{font-size:9px;color:rgba(255,255,255,.7);width:32px;text-align:right;}
.dbfs-big{
  font-family:'Rajdhani',sans-serif;font-size:32px;font-weight:700;
  color:#de9151;line-height:1;letter-spacing:-.01em;
  transition:color .2s,text-shadow .2s;margin-bottom:1px;
  text-shadow:0 0 14px rgba(222,145,81,.5);
}
.dbfs-unit{font-size:9px;color:rgba(255,255,255,.5);letter-spacing:.1em;}

/* Panel tabs */
.panel-tabs{
  display:flex;
  border-bottom:1px solid var(--border);
  flex-shrink:0;
  background:rgba(18,8,0,.35);
}
.ptab{
  flex:1;font-size:8px;letter-spacing:.14em;color:rgba(255,255,255,.35);
  padding:8px 0;text-align:center;cursor:pointer;transition:all .15s;
  border-bottom:2px solid transparent;text-transform:uppercase;
}
.ptab:hover{color:var(--text);}
.ptab.active{
  color:var(--accent);border-bottom-color:var(--accent);
  background:rgba(222,145,81,.04);
  text-shadow:0 0 8px rgba(222,145,81,.5);
}
.ptab.clash-tab.active{
  color:var(--clash);border-bottom-color:var(--clash);
  background:rgba(222,145,81,.04);
  text-shadow:0 0 8px rgba(222,145,81,.5);
}
.panel-page{display:none;flex:1;flex-direction:column;overflow:hidden;}
.panel-page.active{display:flex;}

/* Log */
.log-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:9px 12px 0;
}
.log-header .rp-label{margin-bottom:0;}
.log-actions{display:flex;gap:4px;align-items:center;}
.log-clear{
  font-size:8px;color:rgba(255,255,255,.45);background:none;
  border:1px solid rgba(255,255,255,.08);
  padding:2px 7px;cursor:pointer;transition:all .15s;
  letter-spacing:.1em;text-transform:uppercase;
}
.log-clear:hover{color:var(--danger);border-color:rgba(222,145,81,.5);box-shadow:0 0 8px rgba(222,145,81,.15);}
.log-count{
  font-size:8px;color:rgba(255,255,255,.45);
  background:rgba(222,145,81,.07);
  border:1px solid rgba(222,145,81,.15);
  padding:2px 6px;
}
.log-scroll{flex:1;overflow-y:auto;padding:7px 12px 12px;display:flex;flex-direction:column;gap:4px;}
.log-scroll::-webkit-scrollbar{width:2px;}
.log-scroll::-webkit-scrollbar-thumb{background:rgba(222,145,81,.2);}

/* Log entries */
.log-entry{
  border-left:2px solid var(--danger);
  background:linear-gradient(90deg,rgba(222,145,81,.1) 0%,rgba(222,145,81,.03) 100%);
  padding:6px 9px;opacity:0;transform:translateY(3px);
  transition:opacity .2s,transform .2s;
}
.log-entry.visible{opacity:1;transform:translateY(0);}
.log-entry.warn{
  border-left-color:var(--warn);
  background:linear-gradient(90deg,rgba(168,95,40,.1) 0%,rgba(168,95,40,.03) 100%);
}
.log-entry.clean{
  border-left-color:#de9151;
  background:linear-gradient(90deg,rgba(222,145,81,.08) 0%,rgba(222,145,81,.02) 100%);
}
.log-entry.ongoing{animation:pulse-border 1s ease-in-out infinite;}
.log-entry.ongoing.warn{animation:pulse-border-warn 1s ease-in-out infinite;}
.log-entry.fixed{
  border-left-color:var(--eq-curve)!important;animation:none!important;
  background:linear-gradient(90deg,rgba(222,145,81,.08) 0%,rgba(222,145,81,.02) 100%)!important;
}
@keyframes pulse-border{
  0%,100%{border-left-color:rgba(222,145,81,.3);box-shadow:none}
  50%{border-left-color:#de9151;box-shadow:-3px 0 12px rgba(222,145,81,.4)}
}
@keyframes pulse-border-warn{
  0%,100%{border-left-color:rgba(168,95,40,.3);box-shadow:none}
  50%{border-left-color:#a85f28;box-shadow:-3px 0 12px rgba(168,95,40,.4)}
}
.le-top{display:flex;align-items:flex-start;justify-content:space-between;gap:6px;margin-bottom:3px;}
.le-name{font-size:10px;font-weight:400;color:var(--danger);line-height:1.3;flex:1;letter-spacing:.03em;}
.log-entry.warn .le-name{color:var(--warn);}
.log-entry.clean .le-name{color:#de9151;}
.log-entry.fixed .le-name{color:var(--eq-curve)!important;}
.le-badge{
  font-size:7px;padding:1px 5px;letter-spacing:.12em;
  background:rgba(222,145,81,.15);color:var(--danger);
  flex-shrink:0;white-space:nowrap;border:1px solid rgba(222,145,81,.3);
  text-transform:uppercase;
}
.log-entry.warn .le-badge{background:rgba(168,95,40,.15);color:var(--warn);border-color:rgba(168,95,40,.3);}
.le-meta{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:5px;}
.le-stat{font-size:8px;color:rgba(255,255,255,.75);letter-spacing:.04em;}
.le-stat b{color:#c87840;font-weight:400;}
.le-fix-btn{
  font-size:8px;padding:2px 8px;letter-spacing:.1em;
  border:1px solid rgba(222,145,81,.3);background:rgba(222,145,81,.05);
  color:var(--eq-curve);cursor:pointer;transition:all .15s;text-transform:uppercase;
}
.le-fix-btn:hover{background:rgba(222,145,81,.12);border-color:var(--eq-curve);box-shadow:0 0 8px rgba(222,145,81,.2);}
.le-fix-btn.applied{background:rgba(222,145,81,.15);border-color:var(--eq-curve);opacity:.5;cursor:default;}

/* Clash entries */
.clash-entry{
  border-left:2px solid var(--clash);
  background:linear-gradient(90deg,rgba(222,145,81,.1) 0%,rgba(222,145,81,.03) 100%);
  padding:6px 9px;opacity:0;transform:translateY(3px);
  transition:opacity .2s,transform .2s;
}
.clash-entry.visible{opacity:1;transform:translateY(0);}
.clash-entry.ongoing{animation:pulse-clash 1.2s ease-in-out infinite;}
@keyframes pulse-clash{
  0%,100%{border-left-color:rgba(222,145,81,.3);box-shadow:none}
  50%{border-left-color:#de9151;box-shadow:-3px 0 12px rgba(222,145,81,.5)}
}
.clash-entry.fixed{
  border-left-color:var(--eq-curve)!important;animation:none!important;
  background:linear-gradient(90deg,rgba(222,145,81,.08) 0%,rgba(222,145,81,.02) 100%)!important;
}
.ce-name{font-size:10px;color:var(--clash);line-height:1.3;margin-bottom:3px;letter-spacing:.03em;text-shadow:0 0 8px rgba(222,145,81,.4);}
.clash-entry.fixed .ce-name{color:var(--eq-curve)!important;text-shadow:none!important;}
.ce-badge{font-size:7px;padding:1px 5px;letter-spacing:.12em;background:rgba(222,145,81,.15);color:var(--clash);border:1px solid rgba(222,145,81,.3);text-transform:uppercase;}
.ce-meta{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:5px;}
.ce-stat{font-size:8px;color:rgba(255,255,255,.75);}
.ce-stat b{color:#c87840;font-weight:400;}
.ce-fix-btn{font-size:8px;padding:2px 8px;letter-spacing:.1em;border:1px solid rgba(222,145,81,.3);background:rgba(222,145,81,.05);color:var(--eq-curve);cursor:pointer;transition:all .15s;text-transform:uppercase;}
.ce-fix-btn:hover{background:rgba(222,145,81,.12);border-color:var(--eq-curve);box-shadow:0 0 8px rgba(222,145,81,.2);}
.ce-fix-btn.applied{background:rgba(222,145,81,.15);border-color:var(--eq-curve);opacity:.5;cursor:default;}
.ce-hint{font-size:9px;color:rgba(255,255,255,.8);line-height:1.5;margin-top:4px;border-top:1px solid rgba(222,145,81,.1);padding-top:4px;letter-spacing:.02em;}

/* EQ strip */
.eq-strip{
  padding:10px 12px;
  border-top:1px solid var(--border);flex-shrink:0;
  background:rgba(18,8,0,.25);
}
.eq-band-list{display:flex;flex-direction:column;gap:3px;max-height:95px;overflow-y:auto;}
.eq-band-list::-webkit-scrollbar{width:2px;}
.eq-band-list::-webkit-scrollbar-thumb{background:rgba(222,145,81,.2);}
.eq-band-row{
  display:flex;align-items:center;gap:5px;font-size:9px;
  padding:2px 4px;
  border-left:1px solid rgba(222,145,81,.15);
}
.eqb-col{color:var(--eq-curve);width:12px;text-align:center;flex-shrink:0;text-shadow:0 0 6px rgba(222,145,81,.4);}
.eqb-freq{color:#ffffff;width:40px;}
.eqb-gain{color:#c87840;width:42px;}
.eqb-q{color:rgba(255,255,255,.6);width:28px;}
.eqb-type{color:rgba(255,255,255,.5);flex:1;}
.eqb-src{font-size:8px;color:var(--clash);width:12px;text-align:center;}
.eqb-del{color:rgba(255,255,255,.2);cursor:pointer;transition:color .1s;flex-shrink:0;}
.eqb-del:hover{color:var(--danger);text-shadow:0 0 6px rgba(222,145,81,.5);}
.eq-empty{font-size:9px;color:rgba(255,255,255,.3);text-align:center;padding:8px 0;letter-spacing:.08em;opacity:.5;}
.export-row{display:flex;gap:5px;margin-top:8px;}
.export-daw-wrap{display:flex;gap:5px;width:100%;}
.export-daw-select{
  flex:1;font-family:'Share Tech Mono',monospace;font-size:7px;
  letter-spacing:.06em;padding:3px 6px;
  background:#0f0700;color:rgba(255,255,255,.6);
  border:1px solid rgba(222,145,81,.2);
  outline:none;cursor:pointer;
  appearance:none;-webkit-appearance:none;
}
.export-daw-select:focus{border-color:rgba(222,145,81,.5);}
.export-daw-select option,.export-daw-select optgroup{background:#130a00;color:rgba(255,255,255,.7);}
.export-btn{
  flex:1;font-size:8px;letter-spacing:.1em;color:rgba(255,255,255,.5);
  background:transparent;border:1px solid rgba(222,145,81,.1);
  padding:4px 0;cursor:pointer;transition:all .15s;text-align:center;
  text-transform:uppercase;
  clip-path:polygon(4px 0%,100% 0%,calc(100% - 4px) 100%,0% 100%);
}
.export-btn:hover{color:var(--eq-curve);border-color:rgba(222,145,81,.3);background:rgba(222,145,81,.05);box-shadow:0 0 8px rgba(222,145,81,.1);}

/* ── PROBE BOX ── */
#probeBox{
  position:fixed;
  display:none;
  flex-direction:column;
  gap:3px;
  background:rgba(10,5,0,.92);
  border:1px solid rgba(222,145,81,.45);
  border-left:2px solid rgba(222,145,81,.9);
  padding:8px 12px;
  pointer-events:none;
  z-index:200;
  box-shadow:0 0 18px rgba(222,145,81,.15);
}
.probe-freq{
  font-family:'Rajdhani',sans-serif;
  font-size:18px;font-weight:600;
  color:#fff8e8;
  letter-spacing:.04em;
  text-shadow:0 0 10px rgba(255,210,150,.5);
}
.probe-db{
  font-family:'Share Tech Mono',monospace;
  font-size:11px;
  color:rgba(222,145,81,.9);
  letter-spacing:.08em;
}
.probe-note{
  font-family:'Share Tech Mono',monospace;
  font-size:9px;
  color:rgba(255,255,255,.35);
  letter-spacing:.06em;
  margin-top:1px;
}

.tip-idle{display:flex;flex-direction:column;align-items:center;gap:10px;padding:24px 16px;opacity:.4;}
.tip-idle-icon{font-size:22px;color:var(--accent);}
.tip-idle-text{font-size:9px;color:rgba(255,255,255,.5);text-align:center;line-height:1.6;letter-spacing:.04em;}

.tip-card{
  border-left:2px solid var(--accent);
  background:linear-gradient(90deg,rgba(222,145,81,.08) 0%,rgba(222,145,81,.02) 100%);
  padding:7px 9px;margin-bottom:4px;
  transition:opacity .3s,border-color .3s;
}
.tip-card.fading{opacity:.3;}
.tip-card.inactive{opacity:.18;border-left-color:rgba(222,145,81,.2);}
.tip-header{display:flex;align-items:center;justify-content:space-between;gap:6px;margin-bottom:4px;}
.tip-role{
  font-size:11px;font-weight:600;color:var(--accent);
  font-family:'Rajdhani',sans-serif;letter-spacing:.12em;text-transform:uppercase;
  text-shadow:0 0 8px rgba(222,145,81,.4);
}
.tip-freq{font-size:8px;color:rgba(255,255,255,.45);letter-spacing:.08em;}
.tip-bar-wrap{height:3px;background:rgba(222,145,81,.1);margin-bottom:5px;overflow:hidden;}
.tip-bar{height:100%;background:var(--accent);transition:width .12s;box-shadow:0 0 6px rgba(222,145,81,.5);}
.tip-text{font-size:9px;color:#ffffff;line-height:1.55;letter-spacing:.02em;}
.tip-text b{color:#c87840;font-weight:400;}
.tip-level{font-size:8px;color:rgba(222,145,81,.5);margin-top:3px;letter-spacing:.06em;}
.tip-role-hint{color:rgba(255,255,255,.5)!important;}

.tip-section-head{
  font-size:8px;letter-spacing:.16em;color:rgba(222,145,81,.3);
  text-transform:uppercase;padding:8px 0 4px;
  border-top:1px solid rgba(222,145,81,.06);margin-top:2px;
}

.bottombar{
  height:38px;display:flex;align-items:center;padding:0 14px;gap:14px;
  background:linear-gradient(180deg,#09060a 0%,#060910 100%);
  border-top:1px solid var(--border2);flex-shrink:0;
  box-shadow:0 -1px 20px rgba(222,145,81,.04);
}
.transport-btns{display:flex;gap:4px;}
.t-btn{
  width:28px;height:28px;
  border:1px solid rgba(222,145,81,.15);
  background:rgba(222,145,81,.04);
  color:rgba(255,255,255,.4);cursor:pointer;
  display:flex;align-items:center;justify-content:center;font-size:9px;
  transition:all .12s;
  clip-path:polygon(4px 0%,100% 0%,calc(100% - 4px) 100%,0% 100%);
}
.t-btn:hover{color:var(--accent);border-color:var(--accent);background:rgba(222,145,81,.08);box-shadow:0 0 10px rgba(222,145,81,.15);}
.t-btn.playing{
  background:rgba(222,145,81,.15);color:var(--accent);
  border-color:var(--accent);
  box-shadow:0 0 12px rgba(222,145,81,.3);
  text-shadow:0 0 8px rgba(222,145,81,.7);
}
.t-btn:disabled{opacity:.2;cursor:default;}
.scrubber-wrap{flex:1;display:flex;align-items:center;gap:10px;}
.time-label{font-size:9px;color:rgba(255,255,255,.5);white-space:nowrap;letter-spacing:.06em;}
#scrubber{flex:1;-webkit-appearance:none;height:2px;background:rgba(222,145,81,.1);cursor:pointer;outline:none;}

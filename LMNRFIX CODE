// Musical note from frequency
function freqToNote(f){
  if(f<20)return'';
  const noteNames=['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];
  const semitones=Math.round(12*Math.log2(f/440))+57; // A4=440Hz=MIDI 69, C4=60
  if(semitones<0||semitones>127)return'';
  const note=noteNames[semitones%12];
  const octave=Math.floor(semitones/12)-1;
  const cents=Math.round((12*Math.log2(f/440)+57-semitones)*100);
  const centStr=cents===0?'':(cents>0?` +${cents}¢`:` ${cents}¢`);
  return`${note}${octave}${centStr}`;
}

function formatFreq(f){
  if(f>=1000) return (f/1000).toFixed(f>=10000?1:2)+' kHz';
  return Math.round(f)+' Hz';
}

function updateProbe(clientX,clientY){
  const dpr=window.devicePixelRatio||1;
  const r=canvas.getBoundingClientRect();
  const cx=(clientX-r.left)*dpr;
  const W=canvas.width,H=canvas.height;
  const sr=audioCtx?audioCtx.sampleRate:44100;

  const f=xToFreq(cx,sr,W);

  // Look up dB from last FFT frame
  let db=-80;
  if(lastFreqData&&lastFreqData.length){
    const binSize=sr/FFT;
    const binIdx=Math.round(f/binSize);
    const clamped=Math.max(0,Math.min(lastFreqData.length-1,binIdx));
    db=(lastFreqData[clamped]/255)*80-80;
  }

  probeFreqEl.textContent=formatFreq(f);
  probeDbEl.textContent=db>-79?db.toFixed(1)+' dBFS':'< −79 dBFS';
  probeNoteEl.textContent=freqToNote(f);

  // Position box — keep inside viewport
  const bw=160,bh=72;
  let bx=clientX+18,by=clientY-bh/2;
  if(bx+bw>window.innerWidth-8) bx=clientX-bw-14;
  if(by<8) by=8;
  if(by+bh>window.innerHeight-8) by=window.innerHeight-bh-8;
  probeBox.style.left=bx+'px';
  probeBox.style.top=by+'px';
  probeBox.style.display='flex';
}


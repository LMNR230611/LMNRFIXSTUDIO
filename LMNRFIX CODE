    const typeMap={Bell:'Parametric',HP:'High Pass',LP:'Low Pass',HS:'High Shelf',LS:'Low Shelf'};
    const lines=[
      'LMNRFIX — Studio One Pro EQ Setup Guide',
      '='.repeat(50),'',
      'Studio One .multipreset files use a proprietary binary format.',
      'Apply these settings manually in Pro EQ:','',
      '-'.repeat(50),
    ];
    eqBands.forEach((b,i)=>{
      lines.push(`Band ${i+1}:`);
      lines.push(`  Type      : ${typeMap[b.type]||'Parametric'}`);
      lines.push(`  Frequency : ${b.freq.toFixed(1)} Hz`);
      lines.push(`  Gain      : ${b.gain.toFixed(2)} dB`);
      lines.push(`  Q         : ${b.Q.toFixed(2)}`);
      lines.push('');
    });
    lines.push('— Generated by LMNRFIX');
    content=lines.join('\n');filename='LMNRFIX-StudioOne-ProEQ-Setup.txt';

  } else if(daw==='bitwig'){
    // Bitwig EQ+ — .bwpreset JSON
    const preset={
      name:'LMNRFIX Export',
      creator:'LMNRFIX',
      plugin:'EQ+',
      bands:eqBands.map((b,i)=>({
        index:i+1,
        type:typeLabel(b.type),
        freq:parseFloat(b.freq.toFixed(4)),
        gain:parseFloat(b.gain.toFixed(4)),
        q:parseFloat(b.Q.toFixed(4)),
        enabled:true
      })),
      note:'Import via Bitwig EQ+ > Load Preset'
    };
    content=JSON.stringify(preset,null,2);filename='LMNRFIX-Bitwig-EQPlus.bwpreset';mime='application/json';

  } else if(daw==='reason'){
    // Reason MClass EQ — text reference (Reason doesn't support XML import for MClass)
    const lines=['LMNRFIX — Reason MClass EQ Reference','='.repeat(40),'',
      'Reason\'s MClass EQ has 4 fixed bands. Map the most critical LMNRFIX bands to:',
      '  Band 1 (Lo Cut): use for HP/sub cleanup',
      '  Band 2 (Lo Shelf): use for low-end shaping',
      '  Band 3 (Para Mid): use for primary problem frequency',
      '  Band 4 (Hi Shelf): use for air/presence shaping',''];
    eqBands.forEach((b,i)=>{
      lines.push(`Band ${i+1}: ${typeLabel(b.type)}`);
      lines.push(`  Freq : ${b.freq.toFixed(1)} Hz`);
      lines.push(`  Gain : ${b.gain.toFixed(2)} dB`);
      lines.push(`  Q    : ${b.Q.toFixed(2)}`);
      lines.push('');
    });
    content=lines.join('\n');filename='LMNRFIX-Reason-MClassEQ-Reference.txt';

  } else if(daw==='csv'){
    content='Band,Type,Freq(Hz),Gain(dB),Q,Source\n'+
      eqBands.map((b,i)=>`${i+1},${b.type},${b.freq.toFixed(1)},${b.gain.toFixed(2)},${b.Q.toFixed(2)},${b.clashLabel?'clash':b.zoneLabel?'harm':'manual'}`).join('\n');
    filename='LMNRFIX-EQ.csv';mime='text/csv';

  } else {
    const lines=['LMNRFIX EQ Correction','='.repeat(30),''];
    eqBands.forEach((b,i)=>{
      lines.push(`Band ${i+1}: ${typeLabel(b.type)} [${b.clashLabel?'Clash fix':b.zoneLabel?'Harm fix':'Manual'}]`);
      lines.push(`  Frequency : ${b.freq.toFixed(1)} Hz`);
      lines.push(`  Gain      : ${b.gain.toFixed(2)} dB`);
      lines.push(`  Q         : ${b.Q.toFixed(2)}`);
      lines.push('');
    });
    content=lines.join('\n');filename='LMNRFIX-EQ.txt';
  }

  dl(content,filename,mime);
});

function dl(content,name,mime){const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([content],{type:mime}));a.download=name;a.click();}

// ── Draw ──────────────────────────────────────────────────────
function drawGrid(W,H,sr,dpr){
  ctx.fillStyle='#09060a';ctx.fillRect(0,0,W,H);
  for(let y=0;y<H;y+=4){
    ctx.fillStyle='rgba(16,6,0,0.32)';ctx.fillRect(0,y,W,2);
  }
  for(const db of[-72,-60,-48,-36,-24,-12,0]){
    const y=H-((db+80)/80)*H;
    ctx.beginPath();
    ctx.strokeStyle=db===0?'rgba(222,145,81,.14)':'rgba(222,145,81,.05)';
    ctx.lineWidth=dpr;ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();
    ctx.fillStyle='rgba(222,145,81,.35)';ctx.font=`${9*dpr}px Share Tech Mono`;
    ctx.fillText(db===0?'0 dB':db+'',4*dpr,y-3*dpr);
  }
  for(const f of[20,50,100,200,500,1000,2000,5000,10000,20000]){
    const x=freqToX(f,sr,W);
    ctx.beginPath();ctx.strokeStyle='rgba(222,145,81,.05)';ctx.lineWidth=dpr;
    ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();
    ctx.fillStyle='rgba(222,145,81,.3)';ctx.font=`${9*dpr}px Share Tech Mono`;
    ctx.fillText(f>=1000?(f/1000)+'k':f+'',x+2*dpr,H-4*dpr);
  }
}

function drawHarmZones(W,H,sr,dpr,activeZones){
  for(const z of HARM_ZONES){
    const x1=freqToX(z.min,sr,W),x2=freqToX(z.max,sr,W);
    const g=ctx.createLinearGradient(x1,0,x2,0);
    if(z.sev==='danger'){g.addColorStop(0,'rgba(222,145,81,0)');g.addColorStop(.5,'rgba(222,145,81,.07)');g.addColorStop(1,'rgba(222,145,81,0)');}
    else{g.addColorStop(0,'rgba(168,95,40,0)');g.addColorStop(.5,'rgba(168,95,40,.06)');g.addColorStop(1,'rgba(168,95,40,0)');}
    ctx.fillStyle=g;ctx.fillRect(x1,0,x2-x1,H);
    ctx.fillStyle=z.sev==='danger'?'rgba(222,145,81,.6)':'rgba(168,95,40,.5)';
    ctx.fillRect(x1,0,x2-x1,1.5*dpr);
  }
  if(activeZones){
    for(const z of HARM_ZONES){
      if(!activeZones[z.label])continue;
      const x1=freqToX(z.min,sr,W),x2=freqToX(z.max,sr,W);
      const intens=Math.min(1,(activeZones[z.label].db+40)/40);
      const glow=ctx.createLinearGradient(0,0,0,H);
      if(z.sev==='danger'){glow.addColorStop(0,`rgba(222,145,81,${.25*intens})`);glow.addColorStop(1,'rgba(222,145,81,0)');}
      else{glow.addColorStop(0,`rgba(168,95,40,${.22*intens})`);glow.addColorStop(1,'rgba(168,95,40,0)');}
      ctx.fillStyle=glow;ctx.fillRect(x1,0,x2-x1,H);
    }
  }
}

function drawClashRegions(W,H,sr,dpr,clashes){
  if(!clashEnabled||!clashes||!clashes.length) return;
  for(const c of clashes){
    // Span between the two clashing peaks
    const x1=freqToX(c.freqLo*0.85,sr,W);
    const x2=freqToX(c.freqHi*1.15,sr,W);
    const intens=c.intensity;
    // Vertical gradient fill — purple
    const glow=ctx.createLinearGradient(0,0,0,H);
    glow.addColorStop(0,`rgba(222,145,81,${0.22*intens})`);
    glow.addColorStop(0.5,`rgba(222,145,81,${0.10*intens})`);
    glow.addColorStop(1,'rgba(222,145,81,0)');
    ctx.fillStyle=glow;ctx.fillRect(x1,0,x2-x1,H);
    // Top marker
    ctx.fillStyle=`rgba(222,145,81,${0.55*intens})`;
    ctx.fillRect(x1,0,x2-x1,1.5*dpr);
    // Label
    const cx=(x1+x2)/2;
    ctx.fillStyle=`rgba(222,145,81,${0.6*intens})`;
    ctx.font=`${8*dpr}px DM Mono`;
    ctx.textAlign='center';
    ctx.fillText('⚡',cx,14*dpr);
    ctx.textAlign='left';
    // Bracket lines on sides
    ctx.beginPath();
    ctx.strokeStyle=`rgba(222,145,81,${0.3*intens})`;
    ctx.lineWidth=dpr;
    ctx.setLineDash([3*dpr,3*dpr]);
    ctx.moveTo(x1,0);ctx.lineTo(x1,H*0.7);
    ctx.moveTo(x2,0);ctx.lineTo(x2,H*0.7);
    ctx.stroke();
    ctx.setLineDash([]);
    // Freq labels at bottom of bracket
    ctx.fillStyle=`rgba(222,145,81,${0.45*intens})`;
    ctx.font=`${8*dpr}px DM Mono`;
    ctx.fillText(fmtFreq(c.peakA.freq),x1+2*dpr,H*0.7+10*dpr);
  }
}

function drawEQCurve(W,H,sr,dpr){
  if(!eqBands.length)return;
  ctx.beginPath();let first=true;
  for(let px=0;px<=W;px++){
    const f=xToFreq(px,sr,W),eqDb=totalEQResponse(f),y=H/2-(eqDb/24)*H*0.35;
    if(first){ctx.moveTo(px,H/2);ctx.lineTo(px,y);first=false;}else ctx.lineTo(px,y);
  }
  ctx.lineTo(W,H/2);ctx.closePath();
  const eg=ctx.createLinearGradient(0,0,0,H);
  eg.addColorStop(0,'rgba(222,145,81,.22)');eg.addColorStop(.5,'rgba(196,112,48,.08)');eg.addColorStop(1,'rgba(222,145,81,.01)');
  ctx.fillStyle=eg;ctx.fill();
  // Curve line with glow
  ctx.beginPath();first=true;
  for(let px=0;px<=W;px++){
    const f=xToFreq(px,sr,W),y=H/2-(totalEQResponse(f)/24)*H*0.35;
    first?(ctx.moveTo(px,y),first=false):ctx.lineTo(px,y);
  }
  ctx.strokeStyle='rgba(255,225,185,.95)';ctx.lineWidth=1.5*dpr;
  ctx.shadowColor='rgba(255,200,140,.5)';ctx.shadowBlur=8*dpr;
  ctx.stroke();ctx.shadowBlur=0;
  // 0dB reference
  ctx.beginPath();ctx.strokeStyle='rgba(222,145,81,.12)';ctx.lineWidth=dpr;
  ctx.setLineDash([4*dpr,5*dpr]);ctx.moveTo(0,H/2);ctx.lineTo(W,H/2);ctx.stroke();
  ctx.setLineDash([]);
  // Band nodes
  eqBands.forEach((b,i)=>{
    const p=getBandNodePos(b);
    const isDrag=dragBand&&dragBand.id===b.id;
    const nc=b.clashLabel?'rgba(222,145,81,.9)':'rgba(222,145,81,.9)';
    const sc=b.clashLabel?'rgba(222,145,81,.6)':'rgba(222,145,81,.6)';
    ctx.beginPath();ctx.arc(p.x,p.y,isDrag?12*dpr:8*dpr,0,Math.PI*2);
    ctx.strokeStyle=isDrag?nc:sc;ctx.lineWidth=1.5*dpr;
    ctx.shadowColor=nc;ctx.shadowBlur=isDrag?14*dpr:6*dpr;
    ctx.stroke();ctx.shadowBlur=0;
    ctx.beginPath();ctx.arc(p.x,p.y,5*dpr,0,Math.PI*2);
    ctx.fillStyle=isDrag?nc:(b.clashLabel?'rgba(222,145,81,.8)':'rgba(222,145,81,.8)');ctx.fill();
    ctx.fillStyle='#09060a';ctx.font=`bold ${8*dpr}px Share Tech Mono`;
    ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText(i+1,p.x,p.y);ctx.textAlign='left';ctx.textBaseline='alphabetic';
    ctx.fillStyle=b.clashLabel?'rgba(222,145,81,.6)':'rgba(222,145,81,.5)';
    ctx.font=`${8*dpr}px Share Tech Mono`;
    ctx.fillText(fmtFreq(b.freq),p.x+7*dpr,p.y+13*dpr);
  });
}

function drawSpectrum(freqData,timeData,ct){
  const dpr=window.devicePixelRatio||1;
  const W=canvas.width,H=canvas.height;
  const sr=audioCtx.sampleRate,bins=freqData.length;

  const clashes=detectClashes(freqData,sr);
  drawGrid(W,H,sr,dpr);
  const activeZones={};
  drawHarmZones(W,H,sr,dpr,null);
  drawClashRegions(W,H,sr,dpr,clashes);

  // ── Pre-compute screen points ──
  const pts=[];
  let peakDb=-80;
  for(let i=1;i<bins;i++){
    const f=binFreq(i,sr);
    if(f<15||f>22000)continue;
    const x=freqToX(f,sr,W);
    const db=(freqData[i]/255)*80-80;
    const y=H-((db+80)/80)*H;
    if(db>peakDb)peakDb=db;
    pts.push({x,y,db,f});
    for(const z of HARM_ZONES){
      if(f>=z.min&&f<=z.max){
        const thr=z.sev==='danger'?DTHR:WTHR;
        if(db>thr){
          if(!activeZones[z.label])activeZones[z.label]={sev:z.sev,db:-999};
          if(db>activeZones[z.label].db)activeZones[z.label].db=db;
        }
      }
    }
  }

  // ── Intensity color helper ──
  // Maps dB (-80…0) → color: dark terracotta at low, bright cream at high
  function dbColor(db, alpha){
    const t=Math.max(0,Math.min(1,(db+70)/65)); // 0=quiet, 1=loud
    // deep terracotta → mid orange → light peach → near-white cream
    let r,g,b;
    if(t<0.35){
      // dark terracotta → terracotta
      const s=t/0.35;
      r=Math.round(100+s*122); g=Math.round(45+s*80); b=Math.round(12+s*40);
    } else if(t<0.65){
      // terracotta → warm orange
      const s=(t-0.35)/0.30;
      r=Math.round(222+s*20); g=Math.round(125+s*50); b=Math.round(52+s*40);
    } else if(t<0.85){
      // warm orange → light peach
      const s=(t-0.65)/0.20;
      r=Math.round(242+s*10); g=Math.round(175+s*45); b=Math.round(92+s*68);
    } else {
      // light peach → near-white cream
      const s=(t-0.85)/0.15;
      r=Math.round(252+s*3); g=Math.round(220+s*30); b=Math.round(160+s*80);
    }
    return `rgba(${r},${g},${b},${alpha})`;
  }

  // ── FILL: vertical gradient, drawn once cleanly ──
  ctx.beginPath();
  ctx.moveTo(pts[0].x,H);
  for(let i=0;i<pts.length;i++) ctx.lineTo(pts[i].x,pts[i].y);
  ctx.lineTo(pts[pts.length-1].x,H);
  ctx.closePath();
  const sg=ctx.createLinearGradient(0,0,0,H);
  sg.addColorStop(0,   'rgba(255,220,170,.58)');
  sg.addColorStop(0.18,'rgba(240,175,105,.38)');
  sg.addColorStop(0.42,'rgba(200,120,60,.18)');
  sg.addColorStop(0.68,'rgba(140,72,25,.07)');
  sg.addColorStop(1,   'rgba(50,18,4,.0)');
  ctx.fillStyle=sg;
  ctx.fill();

  // Bloom: second identical fill at low opacity with wide shadow
  ctx.beginPath();
  ctx.moveTo(pts[0].x,H);
  for(let i=0;i<pts.length;i++) ctx.lineTo(pts[i].x,pts[i].y);
  ctx.lineTo(pts[pts.length-1].x,H);
  ctx.closePath();
  ctx.fillStyle='rgba(222,130,60,.10)';
  ctx.shadowColor='rgba(222,145,81,.35)';
  ctx.shadowBlur=20*dpr;
  ctx.fill();
  ctx.shadowBlur=0;

  // ── LINE: single smooth gradient-stroked path ──
  // Build horizontal gradient sampled from actual dB values at each x
  const lineGrad=ctx.createLinearGradient(0,0,W,0);
  const gStep=Math.max(1,Math.floor(pts.length/60));
  for(let i=0;i<pts.length;i+=gStep){
    const pos=Math.min(0.9999,pts[i].x/W);
    lineGrad.addColorStop(pos,dbColor(pts[i].db,0.95));
  }
  lineGrad.addColorStop(1,dbColor(pts[pts.length-1].db,0.95));

  // Bloom pass — single wide path, shadowBlur only
  ctx.beginPath();
  for(let i=0;i<pts.length;i++) i===0?ctx.moveTo(pts[i].x,pts[i].y):ctx.lineTo(pts[i].x,pts[i].y);
  ctx.strokeStyle='rgba(255,200,150,.25)';
  ctx.lineWidth=5*dpr;
  ctx.shadowColor='rgba(255,185,110,.3)';
  ctx.shadowBlur=10*dpr;
  ctx.stroke();
  ctx.shadowBlur=0;

  // Sharp line — single path, gradient fill
  ctx.beginPath();
  for(let i=0;i<pts.length;i++) i===0?ctx.moveTo(pts[i].x,pts[i].y):ctx.lineTo(pts[i].x,pts[i].y);
  ctx.strokeStyle=lineGrad;
  ctx.lineWidth=1.5*dpr;
  ctx.stroke();

  drawHarmZones(W,H,sr,dpr,activeZones);
  drawEQCurve(W,H,sr,dpr);

  // ── Waveform strip ──
  const wH=36*dpr,wY=H-wH;
  ctx.fillStyle='rgba(12,5,0,.85)';ctx.fillRect(0,wY,W,wH);

  // Single path, average color ──
  ctx.beginPath();
  const sl=W/timeData.length;
  for(let i=0;i<timeData.length;i++){
    const y=wY+(timeData[i]/128)*(wH/2);
    i===0?ctx.moveTo(0,y):ctx.lineTo(i*sl,y);
  }
  ctx.strokeStyle='rgba(255,200,150,.70)';
  ctx.lineWidth=dpr;
  ctx.shadowColor='rgba(222,145,81,.4)';
  ctx.shadowBlur=6*dpr;
  ctx.stroke();
  ctx.shadowBlur=0;

  // ── Meters ──
  if(peakDb>-80){
    dbfsBig.textContent=peakDb.toFixed(1);
    const col=peakDb>-6?'#fff8e8':peakDb>-18?'#f0b47a':'#de9151';
    dbfsBig.style.color=col;
    dbfsBig.style.textShadow=`0 0 18px ${col}cc,0 0 45px ${col}44`;
    const pct=dbrng(peakDb);
    meterL.style.width=pct+'%';meterR.style.width=Math.max(0,pct-Math.random()*8)+'%';
    meterLVal.textContent=peakDb.toFixed(1);meterRVal.textContent=(peakDb-Math.random()*2).toFixed(1);
  }

  updateHarmLog(activeZones,ct);
  updateClashLog(clashes,ct);
  updateTips(freqData,sr,ct);
}

function drawIdle(){
  const dpr=window.devicePixelRatio||1,W=canvas.width,H=canvas.height;
  const sr=44100;
  drawGrid(W,H,sr,dpr);
  drawHarmZones(W,H,sr,dpr,null);
  drawEQCurve(W,H,sr,dpr);
}


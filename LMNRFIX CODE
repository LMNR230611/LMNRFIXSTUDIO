<script>
// ── Constants ────────────────────────────────────────────────
const FFT=2048, SMOOTH=0.78;
const HARM_ZONES=[
  {min:0,   max:20,   label:'Infrasound (0–20 Hz)',          sev:'danger'},
  {min:17,  max:20,   label:'Fear freq 17–20 Hz',            sev:'danger'},
  {min:2000,max:4000, label:'Ear sensitivity peak (2–4 kHz)',sev:'warn'},
  {min:8000,max:16000,label:'Tinnitus risk (8–16 kHz)',      sev:'warn'},
  {min:16000,max:22000,label:'Ultrasonic edge (16–22 kHz)',  sev:'warn'},
];
const DTHR=-20, WTHR=-28;
const ZONE_FIX={
  'Infrasound (0–20 Hz)':          {freq:20,   gain:-18,Q:0.7,type:'HP'},
  'Fear freq 17–20 Hz':            {freq:18,   gain:-12,Q:2.0,type:'Bell'},
  'Ear sensitivity peak (2–4 kHz)':{freq:3000, gain:-4, Q:1.4,type:'Bell'},
  'Tinnitus risk (8–16 kHz)':      {freq:10000,gain:-5, Q:1.2,type:'Bell'},
  'Ultrasonic edge (16–22 kHz)':   {freq:16000,gain:-12,Q:0.7,type:'LP'},
};

// Clash detection config
const CLASH_PEAK_THR   = -28;   // dBFS — bin must be this loud to be a peak candidate
const CLASH_PROX_OCT   = 0.5;   // octaves — two peaks within this are "clashing"
const CLASH_DIFF_MAX   = 8;     // dB — if peaks are within this range they mask each other
const CLASH_MIN_PERSIST= 0.4;   // seconds a clash must persist before logging

// Named clash zones (common problem spots in mixing)
const CLASH_RANGES=[
  {lo:60,  hi:200,  name:'Sub/Bass clash',       hint:'Kick and bass often fight here. High-pass bass or cut kick fundamentals.'},
  {lo:200, hi:500,  name:'Low-mid mud',           hint:'Multiple instruments stacking creates mud. Notch around 250–400 Hz.'},
  {lo:500, hi:1200, name:'Midrange congestion',   hint:'Guitars, keys, vocals stack here. Use narrow cuts to carve space.'},
  {lo:1200,hi:3500, name:'Upper-mid harshness',   hint:'Presence clash. Cut 2–3 kHz in the denser instrument.'},
  {lo:3500,hi:8000, name:'Air/Brightness clash',  hint:'Cymbals, hi-hats, vocals competing. High-shelf cut or de-ess.'},
  {lo:8000,hi:22000,name:'High-freq shimmer clash',hint:'Multiple bright sources fighting. LP or shelf cut on non-primary.'},
];

// ── Audio state ──────────────────────────────────────────────
let audioCtx,analyser,srcNode,audioBuf;
let loaded=false,playing=false;
let startTime=0,startOff=0,animId;
// Live BiquadFilter nodes — rebuilt from eqBands whenever bands change
let filterNodes=[];   // array of BiquadFilterNode
let filterHead=null;  // first node in chain (srcNode connects here)
let filterTail=null;  // last node in chain (connects to analyser)

// ── EQ state ─────────────────────────────────────────────────
let eqBands=[], nextBandId=1, eqEnabled=true;
let dragBand=null,dragStartY=0,dragStartGain=0,dragStartX=0;

// ── Clash state ───────────────────────────────────────────────
let clashEnabled=true;
const clashLog=new Map();      // key → {el, firstSeen, lastSeen, peakA, peakB, ongoing, fixed}
let totalClashes=0;
// Smoothed spectrum for clash detection (separate from draw data)
let smoothSpec=null;
// Track active clash regions for canvas drawing
let activeClashRegions=[];     // [{x1,x2,intens}]

// ── Harm log state ───────────────────────────────────────────
const logEntries=new Map();
let totalDetections=0;

// ── DOM ──────────────────────────────────────────────────────
const canvas=document.getElementById('eqCanvas');
const ctx=canvas.getContext('2d');
const eqWrap=document.getElementById('eqWrap');
const dropOverlay=document.getElementById('dropOverlay');
const dropPrompt=document.getElementById('dropPrompt');
const fileInput=document.getElementById('fileInput');
const fileStatus=document.getElementById('fileStatus');
const loadBtn=document.getElementById('loadBtn');
const eqToggle=document.getElementById('eqToggle');
const clashToggle=document.getElementById('clashToggle');
const playBtn=document.getElementById('playBtn');
const stopBtn=document.getElementById('stopBtn');
const scrubber=document.getElementById('scrubber');
const timeCur=document.getElementById('timeCur');
const timeDur=document.getElementById('timeDur');
const dbfsBig=document.getElementById('dbfsBig');
const meterL=document.getElementById('meterL'),meterR=document.getElementById('meterR');
const meterLVal=document.getElementById('meterLVal'),meterRVal=document.getElementById('meterRVal');
const logScroll=document.getElementById('logScroll');
const logCount=document.getElementById('logCount');
const clearBtn=document.getElementById('clearBtn');
const fixAllBtn=document.getElementById('fixAllBtn');
const emptyCard=document.getElementById('emptyCard');
const clashScroll=document.getElementById('clashScroll');
const clashCount=document.getElementById('clashCount');
const clearClashBtn=document.getElementById('clearClashBtn');
const fixAllClashBtn=document.getElementById('fixAllClashBtn');
const clashEmptyCard=document.getElementById('clashEmptyCard');
const statusPill=document.getElementById('statusPill');
const eqBandList=document.getElementById('eqBandList');
const bandCount=document.getElementById('bandCount');
const bandEmpty=document.getElementById('bandEmpty');
const tooltip=document.getElementById('tooltip');
const exportDawBtn=document.getElementById('exportDawBtn');
const dawSelect=document.getElementById('dawSelect');

// ── Panel tabs ────────────────────────────────────────────────
document.querySelectorAll('.ptab').forEach(tab=>{
  tab.addEventListener('click',()=>{
    document.querySelectorAll('.ptab').forEach(t=>t.classList.remove('active'));
    document.querySelectorAll('.panel-page').forEach(p=>p.classList.remove('active'));
    tab.classList.add('active');
    document.getElementById('page-'+tab.dataset.page).classList.add('active');
  });
});

// ── Resize ────────────────────────────────────────────────────
function resize(){
  const dpr=window.devicePixelRatio||1;
  const r=canvas.parentElement.getBoundingClientRect();
  canvas.width=r.width*dpr; canvas.height=r.height*dpr;
  canvas.style.width=r.width+'px'; canvas.style.height=r.height+'px';
}
window.addEventListener('resize',resize);
setTimeout(resize,50);

// ── Helpers ───────────────────────────────────────────────────
function fmt(s){if(isNaN(s)||s<0)return'0:00.0';const m=Math.floor(s/60),ss=Math.floor(s%60),ds=Math.floor((s%1)*10);return`${m}:${ss.toString().padStart(2,'0')}.${ds}`;}
function freqToX(f,sr,w){const a=Math.log10(20),b=Math.log10(sr/2);return((Math.log10(Math.max(f,20))-a)/(b-a))*w;}
function xToFreq(x,sr,w){const a=Math.log10(20),b=Math.log10(sr/2);return Math.pow(10,a+(x/w)*(b-a));}
function binFreq(b,sr){return b*sr/FFT;}
function dbrng(db){return Math.max(0,Math.min(100,(db+80)/80*100));}
function setStatus(t,c=''){statusPill.textContent=t;statusPill.className='status-pill'+(c?' '+c:'');}
function fmtFreq(f){return f>=1000?(f/1000).toFixed(f>=10000?0:1)+'k':Math.round(f)+'';}
function octDist(f1,f2){return Math.abs(Math.log2(f2/f1));}

// ── EQ Math ───────────────────────────────────────────────────
function bandResponse(band,freq){
  const f0=band.freq,G=band.gain,Q=band.Q;
  if(band.type==='HP'){const r=f0/Math.max(freq,1);return -10*Math.log10(1+Math.pow(r,4));}
  if(band.type==='LP'){const r=freq/f0;return -10*Math.log10(1+Math.pow(r,4));}
  const x=Math.log2(freq/f0),sigma=0.5/Q;
  return G*Math.exp(-(x*x)/(2*sigma*sigma));
}
function totalEQResponse(freq){
  if(!eqEnabled) return 0;
  let t=0; for(const b of eqBands) t+=bandResponse(b,freq); return t;
}

// ── EQ Band management ────────────────────────────────────────
function addBand(freq,gain,Q,type,zoneLabel='',clashLabel=''){
  if(zoneLabel && eqBands.find(b=>b.zoneLabel===zoneLabel)) return;
  if(clashLabel && eqBands.find(b=>b.clashLabel===clashLabel)) return;
  const band={id:nextBandId++,freq,gain,Q,type,zoneLabel,clashLabel};
  eqBands.push(band);
  refreshBandList();
  return band;
}

function removeBand(id){
  const b=eqBands.find(x=>x.id===id);
  if(b&&b.zoneLabel){
    const e=logEntries.get(b.zoneLabel);
    if(e){e.fixed=false;e.el.classList.remove('fixed');const btn=e.el.querySelector('.le-fix-btn');if(btn){btn.textContent='+ FIX';btn.classList.remove('applied');}}
  }
  if(b&&b.clashLabel){
    const e=clashLog.get(b.clashLabel);
    if(e){e.fixed=false;e.el.classList.remove('fixed');const btn=e.el.querySelector('.ce-fix-btn');if(btn){btn.textContent='+ FIX';btn.classList.remove('applied');}}
  }
  eqBands=eqBands.filter(x=>x.id!==id);
  refreshBandList();
}

function refreshBandList(){
  eqBandList.innerHTML='';
  bandCount.textContent=eqBands.length+' band'+(eqBands.length!==1?'s':'');
  if(eqBands.length===0){eqBandList.appendChild(bandEmpty);buildFilterChain();if(!playing)drawIdle();return;}
  eqBands.forEach((b,i)=>{
    const row=document.createElement('div');
    row.className='eq-band-row';
    const src=b.clashLabel?'⚡':b.zoneLabel?'⚠':'·';
    row.innerHTML=`<span class="eqb-col">${i+1}</span><span class="eqb-src" title="${b.clashLabel?'clash fix':b.zoneLabel?'harm fix':'manual'}">${src}</span><span class="eqb-freq">${fmtFreq(b.freq)}</span><span class="eqb-gain">${b.gain>0?'+':''}${b.gain.toFixed(1)}dB</span><span class="eqb-q">Q${b.Q.toFixed(1)}</span><span class="eqb-type">${b.type}</span><span class="eqb-del" data-id="${b.id}">✕</span>`;
    row.querySelector('.eqb-del').addEventListener('click',e=>removeBand(Number(e.target.dataset.id)));
    eqBandList.appendChild(row);
  });
  buildFilterChain();
  if(!playing) drawIdle();
}

// ── Web Audio filter chain ────────────────────────────────────
/**
 * Tears down existing BiquadFilter nodes and rebuilds a fresh chain
 * from eqBands. If playing, rewires srcNode through new chain.
 * Chain: srcNode → f0 → f1 → … → fN → analyser → destination
 */
function buildFilterChain(){
  if(!audioCtx) return;

  // Tear down old nodes (disconnect only — GC handles the rest)
  filterNodes.forEach(n=>{try{n.disconnect();}catch(e){}});
  filterNodes=[];

  const activeBands=eqEnabled?eqBands:[];

  if(activeBands.length===0){
    // Bypass: direct srcNode → analyser (reconnect if playing)
    filterHead=null; filterTail=null;
    if(playing&&srcNode){
      try{srcNode.disconnect();}catch(e){}
      srcNode.connect(analyser);
    }
    return;
  }

  // Build new filter nodes
  filterNodes=activeBands.map(band=>{
    const node=audioCtx.createBiquadFilter();
    applyBandToFilter(node,band);
    return node;
  });

  // Chain them together
  for(let i=0;i<filterNodes.length-1;i++){
    filterNodes[i].connect(filterNodes[i+1]);
  }
  filterHead=filterNodes[0];
  filterTail=filterNodes[filterNodes.length-1];
  filterTail.connect(analyser);

  // Rewire source if playing
  if(playing&&srcNode){
    try{srcNode.disconnect();}catch(e){}
    srcNode.connect(filterHead);
  }
}

function applyBandToFilter(node,band){
  node.frequency.value=Math.max(10,Math.min(audioCtx.sampleRate/2-1,band.freq));
  node.gain.value=band.gain;
  node.Q.value=band.Q;
  switch(band.type){
    case 'HP':  node.type='highpass';  node.Q.value=Math.SQRT1_2; break;
    case 'LP':  node.type='lowpass';   node.Q.value=Math.SQRT1_2; break;
    default:    node.type='peaking';   break;
  }
}

// Keep filter params live during drag (no rebuild needed, just update values)
function syncFilterParams(){
  if(!eqEnabled) return;
  const activeBands=eqEnabled?eqBands:[];
  if(filterNodes.length===activeBands.length){
    activeBands.forEach((band,i)=>applyBandToFilter(filterNodes[i],band));
  } else {
    buildFilterChain();
  }
}

function applyZoneFix(zoneLabel){
  const fix=ZONE_FIX[zoneLabel]; if(!fix) return;
  addBand(fix.freq,fix.gain,fix.Q,fix.type,zoneLabel,'');
  const e=logEntries.get(zoneLabel);
  if(e){e.fixed=true;e.el.classList.add('fixed');const btn=e.el.querySelector('.le-fix-btn');if(btn){btn.textContent='✓ APPLIED';btn.classList.add('applied');}}
}

function applyClashFix(key){
  const entry=clashLog.get(key); if(!entry||entry.fixed) return;
  // Cut the quieter of the two peaks by ~3dB with a narrow bell
  const midFreq=Math.sqrt(entry.peakA.freq*entry.peakB.freq);
  const cutFreq=entry.peakA.db<=entry.peakB.db?entry.peakA.freq:entry.peakB.freq;
  addBand(cutFreq,-3.5,2.2,'Bell','',key);
  entry.fixed=true;
  entry.el.classList.add('fixed');
  const btn=entry.el.querySelector('.ce-fix-btn');
  if(btn){btn.textContent='✓ APPLIED';btn.classList.add('applied');}
}

fixAllBtn.addEventListener('click',()=>{for(const[l]of logEntries)applyZoneFix(l);});
fixAllClashBtn.addEventListener('click',()=>{for(const[k]of clashLog)applyClashFix(k);});

eqToggle.addEventListener('click',()=>{
  eqEnabled=!eqEnabled;
  eqToggle.textContent=eqEnabled?'EQ ON':'EQ OFF';
  eqToggle.classList.toggle('eq-active',eqEnabled);
  buildFilterChain();  // rewire audio graph immediately
  if(!playing) drawIdle();
});

clashToggle.addEventListener('click',()=>{
  clashEnabled=!clashEnabled;
  clashToggle.textContent=clashEnabled?'CLASH ON':'CLASH OFF';
  clashToggle.classList.toggle('clash-active',clashEnabled);
});

// ── Canvas mouse ──────────────────────────────────────────────
canvas.addEventListener('mousemove',onCanvasMove);
canvas.addEventListener('mousedown',onCanvasDown);
window.addEventListener('mouseup',()=>{dragBand=null;canvas.style.cursor='crosshair';});

function getBandNodePos(band){
  const dpr=window.devicePixelRatio||1;
  const W=canvas.width,H=canvas.height;
  const sr=audioCtx?audioCtx.sampleRate:44100;
  return{x:freqToX(band.freq,sr,W), y:H/2-((band.gain/24)*H*0.35)};
}

function onCanvasDown(e){
  if(!eqBands.length) return;
  const dpr=window.devicePixelRatio||1;
  const r=canvas.getBoundingClientRect();
  const mx=(e.clientX-r.left)*dpr,my=(e.clientY-r.top)*dpr;
  for(const b of eqBands){
    const p=getBandNodePos(b);
    if(Math.hypot(mx-p.x,my-p.y)<14*dpr){
      dragBand=b;dragStartY=my;dragStartGain=b.gain;dragStartX=mx;
      canvas.style.cursor='grabbing'; break;
    }
  }
}

function onCanvasMove(e){
  const dpr=window.devicePixelRatio||1;
  const r=canvas.getBoundingClientRect();
  const mx=(e.clientX-r.left)*dpr,my=(e.clientY-r.top)*dpr;
  const W=canvas.width,H=canvas.height;
  const sr=audioCtx?audioCtx.sampleRate:44100;
  if(dragBand&&e.buttons===1){
    dragBand.gain=Math.max(-24,Math.min(12,dragStartGain-(my-dragStartY)/(H*0.35)*24));
    if(dragBand.type!=='HP'&&dragBand.type!=='LP'){
      dragBand.freq=Math.max(20,Math.min(sr/2,xToFreq(Math.max(0,Math.min(W,dragStartX+(mx-dragStartX))),sr,W)));
    }
    syncFilterParams();  // update audio in real time while dragging
    refreshBandList();
    showTooltip(e.clientX,e.clientY,`${fmtFreq(dragBand.freq)} Hz · ${dragBand.gain>0?'+':''}${dragBand.gain.toFixed(1)} dB`);
    return;
  }
  let hov=false;
  for(const b of eqBands){
    const p=getBandNodePos(b);
    if(Math.hypot(mx-p.x,my-p.y)<14*dpr){
      canvas.style.cursor='grab';
      showTooltip(e.clientX,e.clientY,`${b.type} · ${fmtFreq(b.freq)} Hz · ${b.gain>0?'+':''}${b.gain.toFixed(1)} dB · Q${b.Q.toFixed(1)}`);
      hov=true; break;
    }
  }
  if(!hov){canvas.style.cursor='crosshair';hideTooltip();}
}


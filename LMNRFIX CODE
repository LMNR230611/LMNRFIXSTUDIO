      'Strong brilliance. Check for <b>harsh resonances</b> with a narrow boosted sweep — if something screams, notch it out.',
    ],
    roleHint:'Hi-hat / cymbal / vocal air / top-end sheen',
    thresh:-30,
  },
  {
    id:'air',lo:10000,hi:16000,label:'Air',
    tips:[
      'Air band active. <b>High shelves on reverb returns</b> here add glue to a mix without adding weight.',
      'Content at 10–16 kHz. Overloading this range causes <b>listener fatigue on headphones</b> — keep it controlled.',
      'Air frequency active. Boosting here on <b>vocals by 1–2 dB opens up space</b> — but only on high-quality recordings.',
      'High air content. <b>Sibilance and cymbal wash</b> pile up here — check if overheads or room mics need a shelf cut.',
    ],
    roleHint:'Vocal air / overhead sheen / reverb tail',
    thresh:-30,
  },
  {
    id:'ultra',lo:16000,hi:22000,label:'Ultra High',
    tips:[
      'Ultra-high content present. Most speakers can\'t reproduce this. <b>Low-pass at 18–20 kHz</b> unless you specifically need it.',
      'Content above 16 kHz. Digital artifacts and <b>aliasing from soft synths</b> often live here — LP to clean up.',
      'Ultra-high energy. On streaming platforms, <b>encoding removes this range anyway</b> — save the headroom.',
      'High frequency content. <b>Low-pass filter everything above 18 kHz</b> for a cleaner, more focused master.',
    ],
    roleHint:'Ultrasonic / aliasing / encoding waste',
    thresh:-35,
  },
];

// State for tips engine
const tipState=new Map(); // id → {card, bar, active, energy, tipIdx, lastTipTime}
let tipsRunning=false;

const tipsScroll=document.getElementById('tipsScroll');
const tipsIdleCard=document.getElementById('tipsIdleCard');
const tipsActive=document.getElementById('tipsActive');

function initTipCards(){
  tipsScroll.innerHTML='';
  tipsScroll.appendChild(tipsIdleCard);
  tipsIdleCard.style.display='flex';
  tipState.clear();
  tipsRunning=false;
  tipsActive.textContent='IDLE';
}

function buildTipCards(){
  tipsScroll.innerHTML='';
  tipState.clear();
  TIP_BANDS.forEach(band=>{
    const card=document.createElement('div');
    card.className='tip-card inactive';
    card.innerHTML=`
      <div class="tip-header">
        <div class="tip-role">${band.label}</div>
        <div class="tip-freq">${fmtFreq(band.lo)}–${fmtFreq(band.hi)} Hz</div>
      </div>
      <div class="tip-bar-wrap"><div class="tip-bar" style="width:0%"></div></div>
      <div class="tip-text tip-role-hint">${band.roleHint}</div>
      <div class="tip-text tip-advice" style="display:none;margin-top:4px;"></div>
      <div class="tip-level"></div>`;
    tipsScroll.appendChild(card);
    tipState.set(band.id,{
      card,
      bar:card.querySelector('.tip-bar'),
      hintEl:card.querySelector('.tip-role-hint'),
      adviceEl:card.querySelector('.tip-advice'),
      levelEl:card.querySelector('.tip-level'),
      active:false,
      energy:-80,
      smoothEnergy:-80,
      tipIdx:Math.floor(Math.random()*band.tips.length),
      lastTipTime:0,
    });
  });
  tipsRunning=true;
}

/**
 * Called every animation frame with the raw frequency byte array.
 * Computes RMS energy per band, updates card activity and tips.
 */
function updateTips(freqData, sr, ct){
  if(!tipsRunning) return;
  const bins=freqData.length;
  let activeCount=0;

  TIP_BANDS.forEach(band=>{
    const state=tipState.get(band.id);
    if(!state) return;

    // Compute average energy in this band
    let sum=0, count=0;
    for(let i=1;i<bins;i++){
      const f=binFreq(i,sr);
      if(f<band.lo) continue;
      if(f>band.hi) break;
      const db=(freqData[i]/255)*80-80;
      sum+=db; count++;
    }
    const avgDb=count>0?sum/count:-80;

    // Smooth energy
    state.smoothEnergy=state.smoothEnergy*0.88+avgDb*0.12;
    const db=state.smoothEnergy;
    const active=db>band.thresh;
    const pct=Math.max(0,Math.min(100,((db+50)/40)*100));

    // Update level bar
    state.bar.style.width=pct+'%';

    // Update level label
    state.levelEl.textContent=db>-79?db.toFixed(1)+' dBFS':'';

    if(active){
      activeCount++;
      state.card.classList.remove('inactive','fading');

      // Rotate tip every 8 seconds of continuous activity
      if(ct-state.lastTipTime>8 || !state.active){
        const tipArr=TIP_BANDS.find(b=>b.id===band.id).tips;
        state.tipIdx=(state.tipIdx+1)%tipArr.length;
        state.adviceEl.innerHTML=tipArr[state.tipIdx];
        state.adviceEl.style.display='block';
        state.hintEl.style.opacity='.4';
        state.lastTipTime=ct;
      }
    } else {
      state.adviceEl.style.display='none';
      state.hintEl.style.opacity='1';
      if(state.active){
        // Just went inactive — fade
        state.card.classList.add('inactive');
      }
    }
    state.active=active;
  });

  tipsActive.textContent=activeCount>0?activeCount+' ACTIVE':'QUIET';
  tipsActive.style.color=activeCount>0?'var(--accent)':'rgba(255,255,255,.35)';
}

// Hook into playback start/stop
const _origBuildFilterChain=buildFilterChain;

// Start tips when playback starts, stop when it stops
function startTips(){
  if(!tipsRunning) buildTipCards();
}
function stopTips(){
  if(tipsRunning){
    tipState.forEach(s=>s.card.classList.add('inactive'));
    tipsActive.textContent='IDLE';
    tipsActive.style.color='rgba(255,255,255,.35)';
  }
}

// ── End production tips engine ────────────────────────────────

setTimeout(drawIdle,100);
</script>

async function loadFile(file){
  stopPlayback(true);
  logEntries.clear();totalDetections=0;logCount.textContent='0';
  clashLog.clear();totalClashes=0;clashCount.textContent='0';
  [...logScroll.children].forEach(el=>{if(el!==emptyCard)el.remove();});
  [...clashScroll.children].forEach(el=>{if(el!==clashEmptyCard)el.remove();});
  emptyCard.style.display='';clashEmptyCard.style.display='';
  setStatus('DECODING…');fileStatus.textContent=file.name;
  if(!audioCtx){
    audioCtx=new(window.AudioContext||window.webkitAudioContext)();
    analyser=audioCtx.createAnalyser();analyser.fftSize=FFT;analyser.smoothingTimeConstant=SMOOTH;
    analyser.connect(audioCtx.destination);  // analyser always feeds destination
  }
  try{
    audioBuf=await audioCtx.decodeAudioData(await file.arrayBuffer());
    smoothSpec=new Float32Array(analyser.frequencyBinCount).fill(-80);
    loaded=true;startOff=0;
    timeDur.textContent=fmt(audioBuf.duration);
    playBtn.disabled=false;stopBtn.disabled=false;
    dropPrompt.classList.add('hidden');
    setStatus('READY','active');
    emptyCard.querySelector('.le-name').textContent='✓ File loaded';
    emptyCard.querySelector('.le-stat').textContent=fmt(audioBuf.duration)+' · '+(audioBuf.sampleRate/1000).toFixed(1)+' kHz';
    clashEmptyCard.querySelector('.ce-name').textContent='✓ File loaded';
    drawIdle();
  }catch(err){setStatus('DECODE ERROR','danger');}
}

// ── Playback ──────────────────────────────────────────────────
function startPlay(off=startOff){
  if(!loaded) return;
  if(audioCtx.state==='suspended') audioCtx.resume();
  srcNode=audioCtx.createBufferSource();srcNode.buffer=audioBuf;
  // Route: srcNode → [filter chain] → analyser → destination
  buildFilterChain();
  if(filterHead) srcNode.connect(filterHead);
  else srcNode.connect(analyser);
  srcNode.start(0,off);
  startTime=audioCtx.currentTime;startOff=off;playing=true;
  startTips();
  playBtn.textContent='⏸';playBtn.classList.add('playing');
  setStatus('ANALYSING','active');
  srcNode.onended=()=>{if(playing){playing=false;startOff=0;scrubber.value=0;timeCur.textContent=fmt(0);playBtn.textContent='▶';playBtn.classList.remove('playing');endAllOngoing();setStatus('DONE','active');}};
  const fd=new Uint8Array(analyser.frequencyBinCount);
  const td=new Uint8Array(analyser.fftSize);
  function loop(){
    if(!playing)return;
    analyser.getByteFrequencyData(fd);analyser.getByteTimeDomainData(td);
    lastFreqData=fd;
    const ct=audioCtx.currentTime-startTime+startOff;
    drawSpectrum(fd,td,ct);
    scrubber.value=Math.min(1000,(ct/audioBuf.duration)*1000);
    timeCur.textContent=fmt(ct);
    animId=requestAnimationFrame(loop);
  }
  loop();
}

function pausePlay(){
  startOff=audioCtx.currentTime-startTime+startOff;
  srcNode.stop();playing=false;cancelAnimationFrame(animId);
  playBtn.textContent='▶';playBtn.classList.remove('playing');
  endAllOngoing();setStatus('PAUSED');
}

function stopPlayback(silent=false){
  if(srcNode){try{srcNode.stop();}catch(e){}}
  playing=false;startOff=0;cancelAnimationFrame(animId);
  playBtn.textContent='▶';playBtn.classList.remove('playing');
  endAllOngoing();
  if(loaded&&!silent){scrubber.value=0;timeCur.textContent=fmt(0);setStatus('STOPPED');}
}

playBtn.addEventListener('click',()=>{if(!loaded)return;playing?pausePlay():startPlay(startOff);});
stopBtn.addEventListener('click',()=>stopPlayback());
scrubber.addEventListener('input',()=>{
  if(!loaded)return;
  const o=(scrubber.value/1000)*audioBuf.duration;
  timeCur.textContent=fmt(o);
  if(playing){pausePlay();startOff=o;startPlay(o);}else{startOff=o;}
});


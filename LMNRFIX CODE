// ── Clash detection ───────────────────────────────────────────
/**
 * Finds clashing frequency pairs in the spectrum.
 * Strategy:
 *  1. Find local peaks above CLASH_PEAK_THR
 *  2. For each pair of peaks within CLASH_PROX_OCT octaves,
 *     if their levels are within CLASH_DIFF_MAX dB → clash
 *  3. Map each clash to a named range
 *  Returns array of {key, rangeLabel, hint, peakA, peakB, freqCenter, intensity}
 */
function detectClashes(freqData, sr) {
  if(!clashEnabled) return [];
  const bins=freqData.length;
  // 1. Find peaks: local maxima above threshold
  const peaks=[];
  for(let i=2;i<bins-2;i++){
    const f=binFreq(i,sr);
    if(f<40||f>20000) continue;
    const db=(freqData[i]/255)*80-80;
    if(db<CLASH_PEAK_THR) continue;
    if(freqData[i]>freqData[i-1]&&freqData[i]>freqData[i+1]&&
       freqData[i]>=freqData[i-2]&&freqData[i]>=freqData[i+2]){
      peaks.push({freq:f,db,bin:i});
    }
  }
  // 2. Find clashing pairs
  const clashes=[];
  const used=new Set();
  for(let a=0;a<peaks.length;a++){
    for(let b=a+1;b<peaks.length;b++){
      const pa=peaks[a],pb=peaks[b];
      if(octDist(pa.freq,pb.freq)>CLASH_PROX_OCT) continue;
      if(Math.abs(pa.db-pb.db)>CLASH_DIFF_MAX) continue;
      const center=Math.sqrt(pa.freq*pb.freq);
      // Find named range
      const range=CLASH_RANGES.find(r=>center>=r.lo&&center<r.hi);
      if(!range) continue;
      const key=range.name;
      const intensity=Math.min(1,(Math.max(pa.db,pb.db)+30)/30);
      if(!used.has(key)){
        used.add(key);
        clashes.push({key,rangeLabel:range.name,hint:range.hint,
          peakA:pa,peakB:pb,freqCenter:center,
          freqLo:Math.min(pa.freq,pb.freq),freqHi:Math.max(pa.freq,pb.freq),
          intensity});
      }
    }
  }
  return clashes;
}

// ── Log update: harm ─────────────────────────────────────────
function updateHarmLog(activeZones,ct){
  for(const[l,e]of logEntries){if(e.ongoing&&!activeZones[l]){e.ongoing=false;e.el.classList.remove('ongoing');refreshHarmMeta(l);}}
  for(const[label,{sev,db}]of Object.entries(activeZones)){
    if(logEntries.has(label)){
      const e=logEntries.get(label);
      e.lastSeen=ct;e.hits++;if(db>e.peakDb)e.peakDb=db;
      if(!e.ongoing){e.ongoing=true;e.el.classList.add('ongoing');totalDetections++;logCount.textContent=totalDetections;}
      refreshHarmMeta(label);
    } else {
      emptyCard.style.display='none';
      totalDetections++;logCount.textContent=totalDetections;
      const alreadyFixed=!!eqBands.find(b=>b.zoneLabel===label);
      const entry={sev,peakDb:db,firstSeen:ct,lastSeen:ct,hits:1,ongoing:true,fixed:alreadyFixed,el:null};
      const el=document.createElement('div');
      el.className=`log-entry ${sev==='warn'?'warn':''} ongoing${alreadyFixed?' fixed':''}`;
      el.innerHTML=`<div class="le-top"><div class="le-name">${label}</div><div class="le-badge">${sev.toUpperCase()}</div></div><div class="le-meta"><span class="le-stat">@ <b class="ts">${fmt(ct)}</b></span><span class="le-stat">peak <b class="pk">${db.toFixed(1)} dB</b></span><span class="le-stat">dur <b class="dur">—</b></span></div><button class="le-fix-btn${alreadyFixed?' applied':''}">${alreadyFixed?'✓ APPLIED':'+ FIX'}</button>`;
      el.querySelector('.le-fix-btn').addEventListener('click',function(){if(!this.classList.contains('applied'))applyZoneFix(label);});
      entry.el=el;logEntries.set(label,entry);
      logScroll.insertBefore(el,logScroll.firstChild);
      setTimeout(()=>el.classList.add('visible'),10);
    }
  }
}
function refreshHarmMeta(l){
  const e=logEntries.get(l);if(!e)return;
  const dur=e.lastSeen-e.firstSeen;
  e.el.querySelector('.pk').textContent=e.peakDb.toFixed(1)+' dB';
  e.el.querySelector('.dur').textContent=dur<0.5?'<0.5s':dur.toFixed(1)+'s';
}

// ── Log update: clashes ───────────────────────────────────────
function updateClashLog(clashes,ct){
  const activeKeys=new Set(clashes.map(c=>c.key));
  for(const[key,entry]of clashLog){
    if(entry.ongoing&&!activeKeys.has(key)){entry.ongoing=false;entry.el.classList.remove('ongoing');refreshClashMeta(key);}
  }
  for(const clash of clashes){
    const{key,rangeLabel,hint,peakA,peakB,intensity}=clash;
    if(clashLog.has(key)){
      const entry=clashLog.get(key);
      entry.lastSeen=ct;
      if(Math.max(peakA.db,peakB.db)>Math.max(entry.peakA.db,entry.peakB.db)){entry.peakA=peakA;entry.peakB=peakB;}
      if(!entry.ongoing){entry.ongoing=true;entry.el.classList.add('ongoing');totalClashes++;clashCount.textContent=totalClashes;}
      refreshClashMeta(key);
    } else {
      clashEmptyCard.style.display='none';
      totalClashes++;clashCount.textContent=totalClashes;
      const alreadyFixed=!!eqBands.find(b=>b.clashLabel===key);
      const entry={peakA,peakB,firstSeen:ct,lastSeen:ct,ongoing:true,fixed:alreadyFixed,el:null};
      const el=document.createElement('div');
      el.className=`clash-entry ongoing${alreadyFixed?' fixed':''}`;
      el.innerHTML=`<div style="display:flex;align-items:flex-start;justify-content:space-between;gap:6px;margin-bottom:3px;"><div class="ce-name">${rangeLabel}</div><div class="ce-badge">CLASH</div></div><div class="ce-meta"><span class="ce-stat">@ <b class="cts">${fmt(ct)}</b></span><span class="ce-stat"><b class="cpf">${fmtFreq(peakA.freq)}</b> vs <b class="cps">${fmtFreq(peakB.freq)}</b></span><span class="ce-stat">dur <b class="cdur">—</b></span></div><button class="ce-fix-btn${alreadyFixed?' applied':''}">${alreadyFixed?'✓ APPLIED':'+ FIX'}</button><div class="ce-hint">${hint}</div>`;
      el.querySelector('.ce-fix-btn').addEventListener('click',function(){if(!this.classList.contains('applied'))applyClashFix(key);});
      entry.el=el;clashLog.set(key,entry);
      clashScroll.insertBefore(el,clashScroll.firstChild);
      setTimeout(()=>el.classList.add('visible'),10);
    }
  }
}
function refreshClashMeta(key){
  const e=clashLog.get(key);if(!e)return;
  const dur=e.lastSeen-e.firstSeen;
  e.el.querySelector('.cdur').textContent=dur<0.5?'<0.5s':dur.toFixed(1)+'s';
  e.el.querySelector('.cpf').textContent=fmtFreq(e.peakA.freq);
  e.el.querySelector('.cps').textContent=fmtFreq(e.peakB.freq);
}

function endAllOngoing(){
  for(const[l,e]of logEntries){if(e.ongoing){e.ongoing=false;e.el.classList.remove('ongoing');refreshHarmMeta(l);}}
  for(const[k,e]of clashLog){if(e.ongoing){e.ongoing=false;e.el.classList.remove('ongoing');refreshClashMeta(k);}}
  stopTips();
}

